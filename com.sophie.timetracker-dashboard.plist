<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sophie.timetracker-dashboard</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>-u</string>
        <string>__DASH_PATH__</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TT_NO_OPEN</key>
        <string>1</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__DATA_DIR__/dashboard.log</string>

    <key>StandardErrorPath</key>
    <string>__DATA_DIR__/dashboard.err.log</string>
</dict>
</plist>
